{
  "name": "mv3-service-worker-smoke",
  "description": "Minimal CRXJS extension with a Playwright smoke test for Manifest V3 service workers.",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "@emnapi/core": "1.11.1",
    "@emnapi/runtime": "1.11.1",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.1.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.0",
    "vite-plugin-zip-pack": "^1.2.4"
  }
}
